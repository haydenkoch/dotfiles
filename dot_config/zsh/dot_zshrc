function brew() {
  command brew "$@"
  case "$1" in
    install|uninstall|remove|reinstall|upgrade)
      command brew bundle dump --force --file="${HOME}/.config/Brewfile"
      print -P "%F{green}✓%f Brewfile updated" >&2
      ;;
  esac
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  COMMAND NOT FOUND
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
typeset -A _missing_cmd_hints=(
  rg  'brew install ripgrep'
  fd  'brew install fd'
  bat 'brew install bat'
  eza 'brew install eza'
  fzf 'brew install fzf'
)

function command_not_found_handler() {
  local cmd="$1"
  shift
  local args="$*"

  print -P "%F{red}zsh:%f command not found: %B${cmd}${args:+ $args}%b" >&2

  if [[ -n "${_missing_cmd_hints[$cmd]}" ]]; then
    print -P "%F{cyan}Install:%f ${_missing_cmd_hints[$cmd]}" >&2
    return 127
  fi

  local i swapped
  for (( i=1; i < ${#cmd}; i++ )); do
    swapped="${cmd[1,i-1]}${cmd[i+1]}${cmd[i]}${cmd[i+2,-1]}"
    if (( $+commands[$swapped] )); then
      print -P "%F{yellow}Did you mean:%f %F{green}%B${swapped}${args:+ $args}%b%f" >&2
      return 127
    fi
  done

  if (( ${#cmd} >= 3 && $+commands[fzf] )); then
    local -a matches
    matches=(${(f)"$(print -l -- ${(ko)commands} | fzf --filter="$cmd" 2>/dev/null | head -5)"})
    if (( ${#matches[@]} )); then
      print -P "%F{yellow}Similar:%f" >&2
      for m in "${matches[@]}"; do
        print -P "  %F{green}${m}${args:+ $args}%f" >&2
      done
    fi
  fi

  return 127
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  FUNCTIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
source "${ZDOTDIR}/tmp.zsh"

function take() {
  if [[ -z "$1" ]]; then
    _usage take '<url|directory>' 'git clone + cd, or mkdir + cd'
    return 1
  fi
  if [[ "$1" == http://* || "$1" == https://* || "$1" == *.git ]]; then
    command git clone --depth 1 "$1" && cd "${${1##*/}%.git}"
  else
    mkcd "$1"
  fi
}

function port() {
  if [[ -z "$1" || "$1" == -* ]]; then
    _usage port '<number>' 'show what is listening on a TCP port'
    return 1
  fi
  command lsof -iTCP:"$1" -sTCP:LISTEN -P -n
}

function regen() {
  local GEN="${ZDOTDIR}/generated"
  mkdir -p "$GEN"

  local -a parts=()

  (( $+commands[mise] )) && {
    mise activate zsh >| "${GEN}/mise.zsh"
    parts+=("${GEN}/mise.zsh")
  }

  (( $+commands[zoxide] )) && {
    zoxide init zsh >| "${GEN}/zoxide.zsh"
    parts+=("${GEN}/zoxide.zsh")
  }

  (( $+commands[fzf] )) && {
    fzf --zsh >| "${GEN}/fzf.zsh"
    parts+=("${GEN}/fzf.zsh")
  }

  (( $+commands[atuin] )) && {
    atuin init zsh >| "${GEN}/atuin.zsh"
    parts+=("${GEN}/atuin.zsh")
  }

  [[ -f "${HOME}/.bun/_bun" ]] && parts+=("${HOME}/.bun/_bun")

  if (( ${#parts} )); then
    cat "${parts[@]}" >| "${GEN}/bundle.zsh"
  else
    : >| "${GEN}/bundle.zsh"
  fi

  zcompile "${GEN}/bundle.zsh"
  zcompile "${ZDOTDIR}/.zshrc"

  echo "✅ cache rebuilt — run 'reload'"
}

function _maybe_regen() {
  local GEN="${ZDOTDIR}/generated"
  local zwc="${GEN}/bundle.zsh.zwc"

  [[ -f "$zwc" ]] || { regen; return }

  local age=$(( EPOCHSECONDS - $(zstat +mtime "$zwc") ))
  (( age > 604800 )) && regen
}

