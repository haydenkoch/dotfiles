# ctrl+z: toggle suspend/resume
function _toggle_fg() {
  if [[ $#BUFFER -eq 0 ]]; then
    BUFFER="fg"
    zle accept-line
  else
    zle push-input
    zle clear-screen
  fi
}
zle -N _toggle_fg
bindkey '^Z' _toggle_fg

# ctrl+f: fix last mistyped command
function _fix_last() {
  local last="${history[$((HISTCMD-1))]}"
  [[ -n "$last" ]] || return
  local first_word="${last%% *}"
  local rest="${last#"$first_word"}"

  local i swapped
  for (( i=1; i < ${#first_word}; i++ )); do
    swapped="${first_word[1,i-1]}${first_word[i+1]}${first_word[i]}${first_word[i+2,-1]}"
    if (( $+commands[$swapped] )); then
      BUFFER="${swapped}${rest}"
      zle accept-line
      return
    fi
  done

  if (( ${#first_word} >= 3 && $+commands[fzf] )); then
    local fix=$(print -l -- ${(ko)commands} | fzf --filter="$first_word" 2>/dev/null | head -1)
    [[ -n "$fix" ]] && BUFFER="${fix}${rest}" && zle accept-line
  fi
}
zle -N _fix_last
bindkey '^F' _fix_last

