# -- state variables (set by hooks, read by prompt) ----
typeset -g _prompt_dir_icon=""
typeset -g _prompt_ctx=""
typeset -g _prompt_ctx_pwd=""
typeset -g _prompt_git=""
typeset -g _prompt_timer=""
typeset -g _prompt_exit=""
typeset -g _prompt_ssh=""
typeset -g _prompt_ssh_set=""
typeset -g _prompt_venv=""
typeset -g _in_git_repo=0
typeset -g _repo_check_pwd=""

# -- project detection (external, first match wins) ───
source "${ZDOTDIR}/project-icons.zsh"

function _prompt_update_ctx() {
  [[ "$PWD" == "$_prompt_ctx_pwd" ]] && return
  _prompt_ctx_pwd="$PWD"
  _prompt_ctx=""

  local rule file icon color
  for rule in "${_project_rules[@]}"; do
    file="${rule%%|*}"
    icon="${${rule#*|}%%|*}"
    color="${rule##*|}"
    if [[ "$file" == \** ]]; then
      local -a found=( ${~file}(N) )
      (( ${#found} )) && {
        _prompt_ctx=" %F{${color}}${icon}%f"
        return
      }
    elif [[ -f "$file" ]]; then
      _prompt_ctx=" %F{${color}}${icon}%f"
      return
    fi
  done
}

# -- chpwd: runs on directory change only ─────────────
function _prompt_update_dir_icon() {
  if [[ "$PWD" == "$HOME" ]]; then
    _prompt_dir_icon="%F{cyan}󰋜%f "
  elif [[ "$PWD" == "${${TMPDIR:-/tmp}%/}/workspaces"* ]]; then
    _prompt_dir_icon="%F{yellow}󰪺%f "
  else
    _prompt_dir_icon="%F{cyan}󰉋%f "
  fi
}

function _prompt_update_repo_state() {
  [[ "$PWD" == "$_repo_check_pwd" ]] && return
  _repo_check_pwd="$PWD"
  command git rev-parse --is-inside-work-tree &>/dev/null
  (( $? == 0 )) && _in_git_repo=1 || _in_git_repo=0
}

function _prompt_chpwd() {
  _prompt_update_dir_icon
  _prompt_update_ctx
  _prompt_update_repo_state
}

add-zsh-hook chpwd _prompt_chpwd
_prompt_chpwd

# -- preexec: runs before each command ─────────────────
function _prompt_preexec() {
  _cmd_start=$EPOCHREALTIME
  print -Pn "\e]0;$1\a"
}

# -- precmd: runs before each prompt ──────────────────
function _prompt_precmd() {
  local last_exit=$?
  print -Pn "\e]0;%3~\a"

  # git
  _prompt_git=""
  if (( _in_git_repo )) && gitstatus_query -t 10 MY 2>/dev/null && [[ "$VCS_STATUS_RESULT" == ok-sync ]]; then
    local branch="${VCS_STATUS_LOCAL_BRANCH:-${VCS_STATUS_COMMIT[1,8]}}"
    local dirty=""
    local s=$VCS_STATUS_NUM_STAGED
    local u=$VCS_STATUS_NUM_UNSTAGED
    local t=$VCS_STATUS_NUM_UNTRACKED
    local a=$VCS_STATUS_NUM_COMMITS_AHEAD
    local b=$VCS_STATUS_NUM_COMMITS_BEHIND
    local c=$VCS_STATUS_NUM_CONFLICTED

    (( s )) && dirty+=" %F{green}󰸞${s}%f"
    (( u )) && dirty+=" %F{yellow}󰏫${u}%f"
    (( t )) && dirty+=" %F{cyan}󰐕${t}%f"
    (( a )) && dirty+=" %F{green}⇡${a}%f"
    (( b )) && dirty+=" %F{red}⇣${b}%f"
    (( c )) && dirty+=" %F{red}󱐋${c}%f"

    _prompt_git=" %F{magenta} ${branch}%f${dirty}"
  fi

  # timer
  _prompt_timer=""
  if [[ -n $_cmd_start ]]; then
    local elapsed=$(( EPOCHREALTIME - _cmd_start ))
    if (( elapsed >= 3 )); then
      printf -v _prompt_timer "%%F{yellow}󱎫 %.1fs%%f" "$elapsed"
    fi
    unset _cmd_start
  fi

  # exit code
  _prompt_exit=""
  (( last_exit )) && _prompt_exit="%F{red} ${last_exit}%f"

  # ssh (compute once per session)
  if [[ -z $_prompt_ssh_set ]]; then
    _prompt_ssh_set=1
    _prompt_ssh=""
    [[ -n "$SSH_CONNECTION" ]] && _prompt_ssh="%F{yellow}󰣀 %n@%m%f "
  fi

  # python venv
  _prompt_venv=""
  [[ -n "$VIRTUAL_ENV" ]] && _prompt_venv="%F{cyan}󰌠 ${VIRTUAL_ENV:t}%f "
}

add-zsh-hook preexec _prompt_preexec
add-zsh-hook precmd  _prompt_precmd

# -- prompt strings ───────────────────────────────────
PROMPT='${_prompt_venv}${_prompt_ssh}${_prompt_dir_icon}%F{magenta}%3~%f${_prompt_ctx}${_prompt_git}%(1j. %F{white}󰜎 %j%f.)
%(?.%F{green}❯%f.%F{red}✘%f) '

